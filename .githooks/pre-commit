#!/bin/bash
# Pre-commit hook for local CI checks + auto-encrypting secrets
# Runs before every commit:
#   1. `just check-precommit` — fast syntax/config checks (<1s)
#   2. Auto-encrypts secrets whose plaintext is newer than the committed .enc
#
# Enable:  git config core.hooksPath .githooks
# (bootstrap.sh does this automatically.)

set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SECRETS_DIR="$DOTFILES_DIR/secrets"

# ──────────────────────────────────────────────────────
# Step 1: Run just check-precommit (fast CI checks)
# ──────────────────────────────────────────────────────
if command -v just &>/dev/null; then
    cd "$DOTFILES_DIR"
    if ! just check-precommit 2>&1; then
        echo "❌ Pre-commit checks failed. Fix the issues above or use --no-verify to skip."
        exit 1
    fi
else
    echo "⚠️  just not installed — skipping fast CI checks (install: brew/cargo install just)"
fi

# ──────────────────────────────────────────────────────
# Step 2: Auto-encrypt secrets
# ──────────────────────────────────────────────────────

# Skip if sops isn't installed
if ! command -v sops &>/dev/null; then
    echo "⚠️  sops not installed — skipping secret auto-encrypt (install: brew/pacman install sops)"
    exit 0
fi

# encrypt_secret <live plaintext path> <enc basename without .enc>
# Returns non-zero (aborting the commit) if encryption fails, so a broken
# encrypt never silently commits a stale secret.
encrypt_secret() {
    local live="$1" name="$2"
    local enc="$SECRETS_DIR/$name.enc"

    [ -f "$live" ] || return 0

    if [ ! -f "$enc" ] || [ "$live" -nt "$enc" ]; then
        echo "🔐 Auto-encrypting $name from $live..."
        # sops selects creation rules by matching the INPUT path against
        # .sops.yaml's path_regex ("secrets/.*"). The live plaintext usually
        # lives elsewhere (e.g. ~/.config/llama.cpp/...), so copy it under
        # secrets/ first. The temp is gitignored (secrets/* with no !un-ignore)
        # and removed immediately, win or lose.
        local staging="$SECRETS_DIR/.tmp.$name"
        local tmpout
        tmpout="$(mktemp)"
        cp "$live" "$staging"
        if sops --encrypt --input-type binary "$staging" >"$tmpout"; then
            rm -f "$staging"
            mv "$tmpout" "$enc"
            git add "$enc"
            echo "   ✅ $name auto-encrypted and added to commit"
        else
            rm -f "$staging" "$tmpout"
            echo "   ❌ Failed to encrypt $name. Aborting commit."
            return 1
        fi
    fi
}

# Generic shell secrets (source ~/.config/secrets/env.fish)
encrypt_secret "$HOME/.config/secrets/env.fish" "env.fish"

# App-specific secrets (live plaintext path -> enc basename)
encrypt_secret "$HOME/.config/llama.cpp/webui-config.json" "llama-webui-config.json"
encrypt_secret "$HOME/dotfiles/pi/agent/auth.json" "pi-auth.json"

# Legacy warning
if [ -f "$HOME/.config/secrets/env.sh" ]; then
    echo "⚠️  Warning: ~/.config/secrets/env.sh exists but is deprecated. Use env.fish instead."
fi

exit 0
