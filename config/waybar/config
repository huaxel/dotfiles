{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "modules-left": [
        "custom/launcher",
        "custom/workspaces"
    ],
    "modules-center": [
        "custom/app-icon"
    ],
    "modules-right": [
        "custom/clipboard",
        "mpris",
        "group/hardware",
        "network",
        "bluetooth",
        "pulseaudio",
        "sway/keyboard-layout",
        "clock",
        "custom/weather",
        "tray"
    ],

    "group/hardware": {
        "orientation": "horizontal",
        "modules": [
            "cpu",
            "memory"
        ]
    },
    "custom/launcher": {
        "format": "яНЕ",
        "on-click": "wofi --show drun",
        "tooltip": false
    },
    "custom/workspaces": {
        "format": "{}",
        "return-type": "json",
        "exec": "/home/juan/.config/waybar/scripts/workspaces.sh",
        "interval": 1,
        "tooltip": false
    },
    "custom/app-icon": {
        "format": "{}",
        "return-type": "json",
        "exec": "/home/juan/.config/waybar/scripts/app-icon.sh",
        "interval": 1,
        "tooltip": true
    },
    "custom/clipboard": {
        "format": "ЁЯУЛ {}",
        "exec": "echo '...'",
        "tooltip": false,
        "on-click": "cliphist list | wofi --dmenu | cliphist decode | wl-copy",
        "on-click-right": "cliphist list | wofi --dmenu --show dmenu | cliphist delete | cliphist list | wofi --show dmenu -p 'Clear clipboard' --action='cliphist decode | wl-copy'"
    },
    "custom/weather": {
        "format": "{}",
        "return-type": "json",
        "exec": "/home/juan/.config/waybar/scripts/weather.sh",
        "interval": 1800,
        "on-click": "xdg-open https://wttr.in"
    },
    "clock": {
        "format": "{:%H:%M} яАЧ ",
        "format-alt": "{:%A, %B %d, %Y (%R)} юк░ ",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "pulseaudio": {
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "яЪй {format_source}",
        "format-source": "{volume}% яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": [
                "яАж",
                "яАз",
                "яАи"
            ]
        },
        "on-click": "pavucontrol"
    },
    "bluetooth": {
        "format": "яКФ {status}",
        "format-connected": "яКФ {num_connections}",
        "format-connected-battery": "яКФ {device_alias} {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "~/.config/sway/scripts/wofi-bluetooth.sh"
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) яЗл",
        "format-ethernet": "{ipaddr}/{cidr} яЮЦ",
        "tooltip-format": "{ifname} via {gwaddr} яЮЦ",
        "format-linked": "{ifname} (No IP) яЮЦ",
        "format-disconnected": "Disconnected тЪа",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "wofi --show drun"
    },
    "cpu": {
        "format": "{usage}% яЛЫ",
        "tooltip": false,
        "on-click": "ghostty -e btop"
    },
    "memory": {
        "format": "{}% яГЙ",
        "on-click": "ghostty -e btop"
    },
    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{status_icon} <i>{dynamic}</i>",
        "player-icons": {
            "default": "тЦ╢",
            "mpv": "ЁЯО╡"
        },
        "status-icons": {
            "paused": "тП╕"
        }
    },
    "sway/keyboard-layout": {
        "format": "{}  тМи",
        "format-click": "{}  тМи",
        "on-click": "~/.config/sway/scripts/switch-kb-layout.sh",
        "xkb-layout-names": ["COLEMAK", "UK"]
    },
    "tray": {
        "spacing": 10
    }
}