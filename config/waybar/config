{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "modules-left": [
        "custom/launcher",
        "custom/workspaces"
    ],
    "modules-center": [
        "custom/app-icon"
    ],
    "modules-right": [
        "custom/clipboard",
        "mpris",
        "group/hardware",
        "network",
        "bluetooth",
        "pulseaudio",
        "sway/keyboard-layout",
        "clock",
        "custom/weather",
        "tray"
    ],

    "group/hardware": {
        "orientation": "horizontal",
        "modules": [
            "cpu",
            "memory"
        ]
    },
    "custom/launcher": {
        "format": "´Źů",
        "on-click": "walker",
        "tooltip": false
    },
    "custom/workspaces": {
        "format": "{}",
        "return-type": "json",
        "exec": "~/.config/waybar/scripts/workspaces.sh",
        "interval": 1,
        "tooltip": false
    },
    "custom/app-icon": {
        "format": "{}",
        "return-type": "json",
        "exec": "~/.config/waybar/scripts/app-icon.sh",
        "interval": 1,
        "max-length": 48,
        "tooltip": true
    },
    "custom/clipboard": {
        "format": "­čôő {}",
        "exec": "echo '...'",
        "tooltip": false,
        "on-click": "cliphist list | wofi --dmenu | cliphist decode | wl-copy",
        "on-click-right": "cliphist list | wofi --dmenu --show dmenu | cliphist delete | cliphist list | wofi --show dmenu -p 'Clear clipboard' --action='cliphist decode | wl-copy'"
    },
    "custom/weather": {
        "format": "{}",
        "return-type": "json",
        "exec": "~/.config/waybar/scripts/weather.sh",
        "interval": 1800,
        "on-click": "xdg-open https://wttr.in"
    },
    "clock": {
        "format": "{:%H:%M} ´ÇŚ ",
        "format-alt": "{:%A, %B %d, %Y (%R)} ţ¬░ ",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "pulseaudio": {
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
        "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
        "format-muted": "´Üę {format_source}",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": [
                "´ÇŽ",
                "´Çž",
                "´ÇĘ"
            ]
        },
        "on-click": "pavucontrol"
    },
    "bluetooth": {
        "format": "´Őö {status}",
        "format-connected": "´Őö {num_connections}",
        "format-connected-battery": "´Őö {device_alias} {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "~/.config/sway/scripts/wofi-bluetooth.sh"
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) ´çź",
        "format-ethernet": "{ipaddr}/{cidr} ´×ľ",
        "tooltip-format": "{ifname} via {gwaddr} ´×ľ",
        "format-linked": "{ifname} (No IP) ´×ľ",
        "format-disconnected": "Disconnected ÔÜá",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "wofi --show drun"
    },
    "cpu": {
        "format": "{usage}% ´őŤ",
