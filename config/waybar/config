        "on-click": "ghostty -e btop"
    },
    "memory": {
        "format": "{}% ´âë",
        "on-click": "ghostty -e btop"
    },
    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{status_icon} <i>{dynamic}</i>",
        "max-length": 32,
        "ellipsis": "ÔÇŽ",
        "player-icons": {
            "default": "ÔľÂ",
            "mpv": "­čÄÁ"
        },
        "status-icons": {
            "paused": "ÔĆŞ"
        }
    },
    "sway/keyboard-layout": {
        "format": "{}  ÔîĘ",
        "format-click": "{}  ÔîĘ",
        "on-click": "~/.config/sway/scripts/switch-kb-layout.sh",
        "xkb-layout-names": ["COLEMAK", "UK"]
    },
    "tray": {
        "spacing": 10
    }
}