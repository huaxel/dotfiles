[
  {
    "id": "exa",
    "name": "Exa Search",
    "enabled": true,
    "url": "https://mcp.exa.ai/mcp?exaApiKey=${EXA_API_KEY}",
    "requestTimeoutSeconds": 30,
    "useProxy": false
  },
  {
    "id": "context7",
    "name": "Context7 Docs",
    "enabled": true,
    "url": "https://mcp.context7.com/mcp",
