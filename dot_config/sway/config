# Read `man 5 sway` for a complete reference.

# Include all module configurations
include /home/juan/.config/sway/config.d/*

## Bluetooth Manager binding and bar
# Bluetooth Manager (Modifier + B)
bindsym $mod+b exec ~/.config/sway/scripts/wofi-bluetooth.sh

# Status Bar (use Waybar as swaybar replacement)
exec systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP

# Toggle keyboard layout using external script (using the working $mod+k binding from keybindings.conf)
# To toggle keyboard layout, press Mod+K instead of Mod+Shift+L