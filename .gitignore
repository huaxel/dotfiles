# ─────────────────────────────────────────────────────────────
# Dotter cache (not config)
# ─────────────────────────────────────────────────────────────
.dotter/cache.toml
.dotter/cache/
.dotter_cache/

# ─────────────────────────────────────────────────────────────
# Private / sensitive configs
# ─────────────────────────────────────────────────────────────
config/gh/private_*
config/zed/private_*
config/zed/conversations/
config/zed/embeddings/
config/zed/prompts/
config/qBittorrent/
config/vscode/globalStorage/
config/vscode/workspaceStorage/
config/vscode/History/
config/vscode/sync/

# ─────────────────────────────────────────────────────────────
# Cache / state / binary files
# ─────────────────────────────────────────────────────────────
config/eza/eza-themes/imgs/
config/eza/eza-themes/test_dir/
config/eza/eza-themes/dot_git/
config/wallpapers/
config/vscode/globalStorage/**/*.vscdb
config/vscode/globalStorage/**/*.vscdb.backup
config/vscode/globalStorage/**/*.json
config/vscode/**/*.vscdb
config/vscode/**/*.vscdb.backup
config/composer/*.lock
config/composer/keys.*
config/tmc/

# ─────────────────────────────────────────────────────────────
# OS files
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────
# Editor files
# ─────────────────────────────────────────────────────────────
*.swp
*.swo
*~
.vscode/
.idea/

# ─────────────────────────────────────────────────────────────
# Local machine config (not shared)
# ─────────────────────────────────────────────────────────────
local/

# Dotter local config (machine-specific)
.dotter/local.toml

# Pi subagents runtime artifacts
.pi-subagents/

# Nested git repos (pi extensions cloned separately)

# ─────────────────────────────────────────────────────────────
# Secrets (decrypted versions — never commit these)
# ─────────────────────────────────────────────────────────────
secrets/*
!secrets/*.enc
!secrets/*.sops
!secrets/.gitkeep
!secrets/README.md

# Age keys (machine-specific)
.config/sops/age/keys.txt
.age-key

# Sops decrypted temp files
*.dec


# Python
__pycache__/
*.pyc
pi/agent/models-store.json
