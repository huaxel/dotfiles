#!/usr/bin/env bash
# Shared git post-receive hook for home server deployments.
# Deployed to ~/deploy-hooks/post-receive and symlinked from each bare repo.
#
# On each git push to main/master, this script:
#   1. Checks out the pushed code to a temp dir
#   2. Auto-detects the project type
#   3. Builds/installs the project
#   4. Moves it to a timestamped release dir
#   5. Swaps the ~/apps/<name>/current symlink
#   6. Starts/restarts the process (systemd, docker, or none for static)
#   7. Writes a Caddy snippet and reloads Caddy
#   8. Prunes old releases

set -euo pipefail

# -----------------------------------------------------------------------------
# Configuration
# -----------------------------------------------------------------------------

APPS_DIR="$HOME/apps"
PORT_REGISTRY="$APPS_DIR/.port-registry.json"
LOG_PREFIX="[home-deploy]"
KEEP_RELEASES=5

# -----------------------------------------------------------------------------
# Helpers
# -----------------------------------------------------------------------------

log() {
  echo "$LOG_PREFIX $*"
}

fail() {
  echo "$LOG_PREFIX ERROR: $*" >&2
  exit 1
}

slugify() {
  # Convert a project name into a valid systemd service name and Caddy hostname
  local name="$1"
  echo "$name" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/-$//;s/^-//'
}

get_server_ip() {
  tailscale ip -4 2>/dev/null || hostname -I | awk '{print $1}'
}

get_server_name() {
  hostname -s
}

ensure_port_registry() {
  if [ ! -f "$PORT_REGISTRY" ]; then
    mkdir -p "$(dirname "$PORT_REGISTRY")"
    echo '{}' > "$PORT_REGISTRY"
  fi
}

# Read/write the port registry. Each project entry is an object:
#   { "external": 8081, "internal": 3001 }
read_registry() {
  ensure_port_registry
  python3 - "$PORT_REGISTRY" <<'PY'
import json, sys
with open(sys.argv[1]) as f:
    print(json.dumps(json.load(f)))
PY
}

write_registry() {
  local data="$1"
  python3 - "$PORT_REGISTRY" "$data" <<'PY'
import json, sys
path, data = sys.argv[1], json.loads(sys.argv[2])
with open(path, "w") as f:
    json.dump(data, f, indent=2)
PY
}

# Assign an external port (Caddy listens on Tailscale IP) for the project.
assign_external_port() {
  local project="$1"
  local assigned
  assigned=$(python3 - "$project" "$PORT_REGISTRY" <<'PY'
import json, sys
project, path = sys.argv[1], sys.argv[2]
try:
    with open(path) as f:
        registry = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    registry = {}
entry = registry.get(project, {})
if "external" in entry:
    print(entry["external"])
    sys.exit(0)
used = {e.get("external") for e in registry.values() if isinstance(e, dict) and e.get("external")}
used.update({e for e in registry.values() if isinstance(e, int)})
for port in range(8080, 9000):
    if port not in used:
        entry["external"] = port
        registry[project] = entry
        with open(path, "w") as f:
            json.dump(registry, f, indent=2)
        print(port)
        sys.exit(0)
print("NO_FREE_PORT", flush=True)
sys.exit(1)
PY
  )
  if [ "$assigned" = "NO_FREE_PORT" ]; then
    fail "No free external port available in range 8080-8999"
  fi
  echo "$assigned"
}

# Assign an internal port (localhost, for Node/Python server apps).
assign_internal_port() {
  local project="$1"
  local assigned
  assigned=$(python3 - "$project" "$PORT_REGISTRY" <<'PY'
import json, sys
project, path = sys.argv[1], sys.argv[2]
try:
    with open(path) as f:
        registry = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    registry = {}
entry = registry.get(project, {})
if "internal" in entry:
    print(entry["internal"])
    sys.exit(0)
used = {e.get("internal") for e in registry.values() if isinstance(e, dict) and e.get("internal")}
for port in range(3000, 4000):
    if port not in used:
        entry["internal"] = port
        registry[project] = entry
        with open(path, "w") as f:
            json.dump(registry, f, indent=2)
        print(port)
        sys.exit(0)
print("NO_FREE_PORT", flush=True)
sys.exit(1)
PY
  )
  if [ "$assigned" = "NO_FREE_PORT" ]; then
    fail "No free internal port available in range 3000-3999"
  fi
  echo "$assigned"
}

# -----------------------------------------------------------------------------
# Project type detection
# -----------------------------------------------------------------------------

detect_project_type() {
  local dir="$1"
  if [ -f "$dir/docker-compose.yml" ] || [ -f "$dir/docker-compose.yaml" ]; then
    echo "docker-compose"
    return
  fi
  if [ -f "$dir/Dockerfile" ]; then
    echo "docker"
    return
  fi
  if [ -f "$dir/package.json" ]; then
    local has_vite_static has_build_script
    has_vite_static=$(node -e "
      const p = require('$dir/package.json');
      const deps = {...(p.dependencies || {}), ...(p.devDependencies || {})};
      const markers = ['vite', 'svelte', 'astro', 'next', '@sveltejs/vite-plugin'];
      process.exit(markers.some(m => deps[m]) ? 0 : 1);
    " 2>/dev/null && echo yes || echo no)
    has_build_script=$(node -e "
      const p = require('$dir/package.json');
      process.exit(p.scripts && p.scripts.build ? 0 : 1);
    " 2>/dev/null && echo yes || echo no)

    if [ "$has_vite_static" = "yes" ] || [ "$has_build_script" = "yes" ]; then
      # If there's a start/serve script alongside a build, it's likely a server
      local has_start_script
      has_start_script=$(node -e "
        const p = require('$dir/package.json');
        process.exit(p.scripts && (p.scripts.start || p.scripts.serve) ? 0 : 1);
      " 2>/dev/null && echo yes || echo no)
      if [ "$has_vite_static" = "yes" ] && [ "$has_start_script" = "no" ]; then
        echo "node-static"
      else
        echo "node-server"
      fi
    else
      echo "node-server"
    fi
    return
  fi
  if [ -f "$dir/pyproject.toml" ] || [ -f "$dir/requirements.txt" ]; then
    echo "python"
    return
  fi
  echo "static"
}

# -----------------------------------------------------------------------------
# Build / install per project type
# -----------------------------------------------------------------------------

build_static() {
  local src="$1" release="$2"
  cp -a "$src/." "$release/"
}

# Read an optional Procfile at the project root.
# Format: web: <command>  or  build: <command>
read_procfile() {
  local src="$1" key="$2"
  if [ -f "$src/Procfile" ]; then
    grep "^$key:" "$src/Procfile" | sed -E "s/^$key:\s*//" | head -n1
  fi
}

build_node_static() {
  local src="$1" release="$2"
  local build_cmd
  build_cmd=$(read_procfile "$src" "build")

  cd "$src"
  if [ -f "pnpm-lock.yaml" ]; then
    pnpm install
  elif [ -f "package-lock.json" ]; then
    npm ci
  elif [ -f "yarn.lock" ]; then
    yarn install
  else
    npm install
  fi

  if [ -n "$build_cmd" ]; then
    eval "$build_cmd"
  elif node -e "process.exit(require('./package.json').scripts && require('./package.json').scripts.build ? 0 : 1)" 2>/dev/null; then
    if [ -f "pnpm-lock.yaml" ]; then
      pnpm run build
    else
      npm run build
    fi
  else
    log "No 'build' script in package.json; serving source files"
  fi
  cd - >/dev/null

  # Copy only the dist/ directory if a build produced one
  if [ -d "$src/dist" ]; then
    cp -a "$src/dist" "$release/"
  elif [ -d "$src/build" ]; then
    cp -a "$src/build" "$release/"
  else
    # Serve source files, but skip node_modules
    rsync -a --exclude=node_modules --exclude=.git "$src/" "$release/"
  fi
}

build_node_server() {
  local src="$1" release="$2"
  cd "$src"
  if [ -f "pnpm-lock.yaml" ]; then
    pnpm install
  elif [ -f "package-lock.json" ]; then
    npm ci
  elif [ -f "yarn.lock" ]; then
    yarn install
  else
    npm install
  fi

  local build_cmd
  build_cmd=$(read_procfile "$src" "build")
  if [ -n "$build_cmd" ]; then
    eval "$build_cmd"
  elif node -e "process.exit(require('./package.json').scripts && require('./package.json').scripts.build ? 0 : 1)" 2>/dev/null; then
    if [ -f "pnpm-lock.yaml" ]; then
      pnpm run build
    else
      npm run build
    fi
  fi
  cd - >/dev/null
  cp -a "$src/." "$release/"
}

build_python() {
  local src="$1" release="$2"
  cp -a "$src/." "$release/"
  cd "$release"
  if command -v uv >/dev/null 2>&1 && [ -f "pyproject.toml" ]; then
    uv sync --no-dev || uv pip install -e .
  elif [ -f "requirements.txt" ]; then
    python3 -m venv .venv
    .venv/bin/pip install -r requirements.txt
  elif [ -f "pyproject.toml" ]; then
    python3 -m venv .venv
    .venv/bin/pip install -e .
  fi
  cd - >/dev/null
}

build_docker() {
  local src="$1" release="$2" project="$3"
  cp -a "$src/." "$release/"
  cd "$release"
  docker build -t "home-deploy/$project:latest" .
  cd - >/dev/null
}

build_docker_compose() {
  local src="$1" release="$2"
  cp -a "$src/." "$release/"
  # Nothing to pre-build; docker compose handles it
}

# -----------------------------------------------------------------------------
# Process management
# -----------------------------------------------------------------------------

write_systemd_service() {
  local project="$1"
  local service_name="$2"
  local port="$3"
  local type="$4"
  local release="$5"

  mkdir -p "$HOME/.config/systemd/user"
  local service_file="$HOME/.config/systemd/user/$service_name.service"

  local exec_cmd
  local web_cmd
  web_cmd=$(read_procfile "$release" "web")

  case "$type" in
    node-server)
      if [ -n "$web_cmd" ]; then
        exec_cmd="/usr/bin/env PORT=$port NODE_ENV=production sh -c 'cd $release && $web_cmd'"
      else
        # Prefer the start script
        exec_cmd="/usr/bin/env PORT=$port NODE_ENV=production /usr/bin/npm start"
      fi
      ;;
    python)
      if [ -n "$web_cmd" ]; then
        exec_cmd="/usr/bin/env PORT=$port sh -c 'cd $release && $web_cmd'"
      elif [ -f "$release/.venv/bin/python" ]; then
        exec_cmd="/usr/bin/env PORT=$port $release/.venv/bin/python $release/main.py"
      else
        exec_cmd="/usr/bin/env PORT=$port python3 $release/main.py"
      fi
      ;;
  esac

  cat > "$service_file" <<EOF
[Unit]
Description=$project home deploy service
After=network.target

[Service]
Type=simple
WorkingDirectory=$release
ExecStart=$exec_cmd
Restart=on-failure
RestartSec=5
Environment=PORT=$port
Environment=NODE_ENV=production

[Install]
WantedBy=default.target
EOF

  systemctl --user daemon-reload
  systemctl --user enable --now "$service_name"
  systemctl --user restart "$service_name"
}

run_docker() {
  local project="$1"
  local external_port="$2"
  local release="$3"
  local tag="home-deploy/$project:latest"

  docker build -t "$tag" "$release"
  docker rm -f "$project" 2>/dev/null || true
  docker run -d --name "$project" \
    -p "127.0.0.1:$external_port:80" \
    --restart unless-stopped \
    "$tag"
}

run_docker_compose() {
  local project="$1"
  local external_port="$2"
  local release="$3"
  cd "$release"
  # Stop any previous compose project with the same name
  docker compose down 2>/dev/null || true
  EXTERNAL_PORT="$external_port" docker compose up -d --build
  cd - >/dev/null
}

# -----------------------------------------------------------------------------
# Caddy snippet generation
# -----------------------------------------------------------------------------

write_caddy_snippet() {
  local project="$1"
  local type="$2"
  local external_port="$3"
  local internal_port="$4"
  local release="$5"
  local server_ip

  server_ip=$(get_server_ip)
  local current_dir="$APPS_DIR/$project/current"
  local snippet="$release/Caddyfile"
  local site_address="$server_ip:$external_port"

  case "$type" in
    node-static|static)
      local root_dir
      if [ -d "$release/dist" ]; then
        root_dir="$current_dir/dist"
      else
        root_dir="$current_dir"
      fi
      cat > "$snippet" <<EOF
http://$site_address {
    bind $server_ip
    root * $root_dir
    file_server
    encode gzip
}
EOF
      ;;
    node-server|python)
      cat > "$snippet" <<EOF
http://$site_address {
    bind $server_ip
    reverse_proxy localhost:$internal_port
    encode gzip
}
EOF
      ;;
    docker|docker-compose)
      cat > "$snippet" <<EOF
http://$site_address {
    bind $server_ip
    reverse_proxy localhost:$external_port
    encode gzip
}
EOF
      ;;
  esac
}

reload_caddy() {
  # Caddy user service will auto-reload its config via SIGHUP or ExecReload
  systemctl --user reload-or-restart caddy || true
}

# -----------------------------------------------------------------------------
# Main hook
# -----------------------------------------------------------------------------

main() {
  local newrev ref
  # oldrev is ignored; we only need the new revision being pushed
  read -r _ newrev ref

  # Only deploy main or master
  case "$ref" in
    refs/heads/main|refs/heads/master) ;;
    *)
      log "Ignoring push to $ref (only main/master trigger deploy)"
      exit 0
      ;;
  esac

  local repo_dir
  repo_dir=$(pwd)
  local project
  project=$(basename "$repo_dir" .git)
  local service_name
  service_name=$(slugify "$project")
  local timestamp
  timestamp=$(date +%Y%m%d-%H%M%S)

  local release_dir="$APPS_DIR/$project/releases/$timestamp"
  local current_link="$APPS_DIR/$project/current"
  local tmp_worktree
  tmp_worktree=$(mktemp -d)

  log "Deploying $project (ref: $ref)"

  # 1. Checkout
  git --work-tree="$tmp_worktree" --git-dir="$repo_dir" checkout -f "$newrev" -- .

  # 2. Detect project type
  local project_type
  project_type=$(detect_project_type "$tmp_worktree")
  log "Detected project type: $project_type"

  # 3. Assign ports
  local external_port internal_port=""
  external_port=$(assign_external_port "$project")
  log "Assigned external port: $external_port"
  case "$project_type" in
    node-server|python)
      internal_port=$(assign_internal_port "$project")
      log "Assigned internal port: $internal_port"
      ;;
  esac

  # 4. Build
  mkdir -p "$release_dir"
  case "$project_type" in
    static) build_static "$tmp_worktree" "$release_dir" ;;
    node-static) build_node_static "$tmp_worktree" "$release_dir" ;;
    node-server) build_node_server "$tmp_worktree" "$release_dir" ;;
    python) build_python "$tmp_worktree" "$release_dir" ;;
    docker) build_docker "$tmp_worktree" "$release_dir" "$project" "$external_port" ;;
    docker-compose) build_docker_compose "$tmp_worktree" "$release_dir" "$project" "$external_port" ;;
  esac

  # 5. Write .env with port(s) if needed
  if [ -n "$internal_port" ]; then
    echo "PORT=$internal_port" >> "$release_dir/.env"
  fi
  echo "EXTERNAL_PORT=$external_port" >> "$release_dir/.env"

  # 6. Install release and swap symlink
  # Ensure parent directory exists before symlinking
  mkdir -p "$(dirname "$current_link")"
  ln -sfn "$release_dir" "$current_link"
  log "Current symlink updated to $release_dir"

  # 7. Start/restart process
  case "$project_type" in
    node-server|python)
      write_systemd_service "$project" "$service_name" "$internal_port" "$project_type" "$release_dir"
      ;;
    docker)
      run_docker "$project" "$external_port" "$release_dir"
      ;;
    docker-compose)
      run_docker_compose "$project" "$external_port" "$release_dir"
      ;;
    *)
      log "No process to start for static project"
      ;;
  esac

  # 8. Write Caddy snippet and reload
  write_caddy_snippet "$project" "$project_type" "$external_port" "$internal_port" "$release_dir"
  reload_caddy

  # 9. Prune old releases
  local all_releases count=0 release
  mapfile -t all_releases < <(find "$APPS_DIR/$project/releases" -mindepth 1 -maxdepth 1 -printf '%f\n' | sort -r)
  for release in "${all_releases[@]}"; do
    count=$((count + 1))
    if [ "$count" -gt "$KEEP_RELEASES" ]; then
      rm -rf "$APPS_DIR/$project/releases/$release"
      log "Pruned old release: $release"
    fi
  done

  # 10. Cleanup
  rm -rf "$tmp_worktree"

  log "Deploy of $project complete. Access at http://$(get_server_ip):$external_port"
}

main
