# Chezmoi configuration - auto-generated on init
# Run `chezmoi init` to regenerate

[git]
    autoCommit = false
    autoPush = false

[edit]
    command = "nvim"

[diff]
    pager = "delta"

[merge]
    command = "nvim"
    args = ["-d", "{{ .Target }}", "{{ .Source }}", "{{ .TemplateTarget }}"]

[script]
    stopOnError = false
